      <key>Weekday</key><integer>6</integer>
      <key>Hour</key><integer>4</integer>
      <key>Minute</key><integer>30</integer>
    </dict>
  </array>

  <key>StandardOutPath</key>
  <string>/Users/kiki/astcok/factor_research/logs/daily_update/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/kiki/astcok/factor_research/logs/daily_update/launchd.err.log</string>
</dict>
</plist>
