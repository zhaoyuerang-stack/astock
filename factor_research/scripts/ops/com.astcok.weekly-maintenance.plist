<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.astcok.weekly-maintenance</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/Users/kiki/astcok/factor_research/scripts/ops/scheduled_weekly_maintenance.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/kiki/astcok/factor_research</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>7</integer>
    <key>Hour</key>
    <integer>2</integer>
    <key>Minute</key>
    <integer>30</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/kiki/astcok/factor_research/logs/weekly_maintenance/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/kiki/astcok/factor_research/logs/weekly_maintenance/launchd.err.log</string>
</dict>
</plist>
