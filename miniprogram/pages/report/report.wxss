.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-page);
}
.content {
  flex: 1;
  overflow-y: auto;
}

/* 裁决卡 */
.verdict-card {
  margin: 16px;
  padding: 20px;
  border-radius: var(--radius-xl);
  border: 0.5px solid;
  text-align: center;
}
.verdict-card.falsified {
  background: var(--danger-bg);
  border-color: var(--danger-border);
}
.verdict-card.viable {
  background: var(--success-bg);
  border-color: #6EE7B7;
}
.verdict-card.inconclusive {
  background: var(--warning-bg);
  border-color: var(--warning);
}
.verdict-label {
  font-size: 10px;
  color: var(--text-secondary);
  letter-spacing: 1.5px;
  text-transform: uppercase;
  font-weight: 500;
}
.verdict-title {
  font-size: 22px;
  font-weight: 500;
  margin-top: 6px;
  letter-spacing: 0.5px;
}
.verdict-card.falsified .verdict-title {
  color: var(--danger);
}
.verdict-card.viable .verdict-title {
  color: var(--success);
}
.verdict-card.inconclusive .verdict-title {
  color: var(--warning);
}
.verdict-sub {
  font-size: 12px;
  margin-top: 5px;
  opacity: 0.85;
}
.verdict-card.falsified .verdict-sub {
  color: var(--danger);
}
.verdict-card.viable .verdict-sub {
  color: var(--success);
}
.verdict-card.inconclusive .verdict-sub {
  color: var(--warning);
}

/* 摘要卡 */
.summary-card {
  margin: 0 16px 12px;
  padding: 14px 16px;
}
.summary-row {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  padding: 4px 0;
  gap: 12px;
}
.summary-row .k {
  color: var(--text-tertiary);
  flex-shrink: 0;
}
.summary-row .v {
  color: var(--text-primary);
  font-weight: 500;
  text-align: right;
}

/* KPI */
.kpi-grid {
  margin: 0 16px 12px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}
.kpi {
  background: var(--bg-subtle);
  border-radius: var(--radius-md);
  padding: 12px 8px;
  text-align: center;
}
.kpi-label {
  font-size: 9px;
  color: var(--text-tertiary);
  letter-spacing: 0.6px;
  text-transform: uppercase;
  font-weight: 500;
}
.kpi-value {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
  margin-top: 4px;
}
.kpi.up .kpi-value {
  color: var(--success);
}
.kpi.dn .kpi-value {
  color: var(--danger);
}

/* Gate 区 */
.gate-section {
  margin: 0 16px 12px;
  padding: 0;
  overflow: hidden;
}
.gate-header {
  padding: 10px 14px;
  border-bottom: 0.5px solid var(--border);
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  font-weight: 500;
  color: var(--text-secondary);
  letter-spacing: 0.5px;
  background: var(--bg-subtle);
}
.gate-count {
  color: var(--success);
}
.gate-row {
  display: flex;
  align-items: center;
  padding: 11px 14px;
  border-bottom: 0.5px solid var(--border-light);
  font-size: 13px;
}
.gate-row:last-child {
  border-bottom: none;
}
.gate-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  margin-right: 11px;
  flex-shrink: 0;
}
.gate-dot.pass {
  background: var(--success);
}
.gate-dot.fail {
  background: var(--danger);
}
.gate-dot.warn {
  background: var(--warning);
}
.gate-name {
  flex: 1;
  color: var(--text-primary);
  display: flex;
  align-items: center;
}
.gate-id {
  color: var(--text-tertiary);
  font-size: 11px;
  margin-right: 8px;
}
.gate-status {
  font-size: 11px;
  font-weight: 500;
}
.gate-status.pass {
  color: var(--success);
}
.gate-status.fail {
  color: var(--danger);
}
.gate-status.warn {
  color: var(--warning);
}

/* 原因卡 */
.why-card {
  margin: 0 16px 12px;
  padding: 14px 16px;
  border-left: 2px solid var(--danger);
}
.why-title {
  font-size: 11px;
  font-weight: 500;
  color: var(--text-secondary);
  letter-spacing: 0.8px;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.why-item {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  margin-bottom: 6px;
}
.why-bullet {
  color: var(--danger);
  font-weight: 500;
  flex-shrink: 0;
}
.why-text {
  font-size: 12px;
  color: var(--text-secondary);
  line-height: 1.75;
  flex: 1;
}

/* 详情入口 */
.detail-link {
  margin: 0 16px 16px;
  padding: 12px;
  background: var(--bg-card);
  border: 0.5px solid var(--primary);
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 12px;
  color: var(--primary);
  font-weight: 500;
}

/* 空状态 */
.empty {
  justify-content: center;
  align-items: center;
}
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px;
}
.empty-icon {
  font-size: 48px;
  color: var(--text-tertiary);
  margin-bottom: 16px;
}
.empty-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 8px;
}
.empty-desc {
  font-size: 13px;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 24px;
}
.empty-cta {
  background: var(--primary);
  color: #fff;
  border: 0.5px solid var(--primary);
  padding: 10px 24px;
  border-radius: var(--radius-md);
  font-size: 13px;
  font-weight: 500;
}
.empty-cta::after {
  border: none;
}
